# Utilise l'image officielle Playwright (contient déjà Node.js + navigateurs)
FROM mcr.microsoft.com/playwright:v1.56.0-jammy

# Définit le dossier de travail dans le conteneur
WORKDIR /app

# Copie les fichiers de dépendances en premier (optimisation du cache Docker)
COPY package.json package-lock.json ./

# Installe les dépendances exactement comme défini dans package-lock.json
RUN npm ci

# Copie le reste du projet
COPY . .

# Installe uniquement Chromium (déjà présent dans l'image de base, mais garantit la cohérence)
RUN npx playwright install chromium --with-deps

# Commande par défaut : lance les tests sur Chromium uniquement
CMD ["npx", "playwright", "test", "--project=chromium"]
